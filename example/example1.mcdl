include "random"
include "mathlib.mcdl"
typedef int i32

fn foo() -> i32;
@init
fn bar(){
    if (foo()==350234) {
        exec("say 𝔀𝓪𝔀")
        print("1")
    }else {
        exec("say 2")
    }
}

@target("java")
fn foo() -> i32{
    return 350234
}

@target("be")
fn foo() -> i32{
    return 0
}
