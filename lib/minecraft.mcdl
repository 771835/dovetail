fn playsound_voice(sound: string, targets: string = "", pos: string = "", volume: string = "", pitch: string = "", minVolume: string = "") {
    if (targets == "") {
        exec(f"playsound {sound} voice")
    } else if (pos == "") {
        exec(f"playsound {sound} voice {targets}")
    } else if (volume == "") {
        exec(f"playsound {sound} voice {targets} {pos}")
    } else if (pitch == "") {
        exec(f"playsound {sound} voice {targets} {pos} {volume}")
    } else if (minVolume == "") {
