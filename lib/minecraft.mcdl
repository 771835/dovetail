// ────────────────────────────────────────────────────────────
// xp
// ────────────────────────────────────────────────────────────

// (无可执行子命令)

// ────────────────────────────────────────────────────────────
// 命令别名（tp → teleport，w/msg → tell 等）
// ────────────────────────────────────────────────────────────

fn tp(targets: string, location: string = "", rotation: string = "", destination: string = "") {
    if (location == "") {
        exec(f"tp {destination}")
    } else if (targets == "") {
        exec(f"tp {location}")
    } else if (location == "") {
        exec(f"tp {targets} {destination}")
    } else if (rotation == "") {
        exec(f"tp {targets} {location}")
    } else {
        exec(f"tp {targets} {location} {rotation}")
    }
}

fn tp_facing_entity(targets: string, location: string, facingEntity: string, facingAnchor: string = "") {
    if (facingAnchor == "") {
        exec(f"tp {targets} {location} facing entity {facingEntity}")
    } else {
        exec(f"tp {targets} {location} facing entity {facingEntity} {facingAnchor}")
    }
}

fn tp_facing(targets: string, location: string, facingLocation: string) {
    exec(f"tp {targets} {location} facing {facingLocation}")
}

fn wraw(targets: string, message: string) {
    exec(f"w {targets} {message}")
}

fn msgraw(targets: string, message: string) {
    exec(f"msg {targets} {message}")
}
