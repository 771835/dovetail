// ────────────────────────────────────────────────────────────
// damage
// ────────────────────────────────────────────────────────────

fn damage(target: string, amount: string, damageType: string = "") {
    if (damageType == "") {
        exec(f"damage {target} {amount}")
    } else {
        exec(f"damage {target} {amount} {damageType}")
    }
}

fn damage_at(target: string, amount: string, damageType: string, location: string) {
    exec(f"damage {target} {amount} {damageType} at {location}")
}

fn damage_by(target: string, amount: string, damageType: string, entity: string) {
    exec(f"damage {target} {amount} {damageType} by {entity}")
}

fn damage_by_from(target: string, amount: string, damageType: string, entity: string, cause: string) {
    exec(f"damage {target} {amount} {damageType} by {entity} from {cause}")
}

