        exec(f"effect clear")
    } else if (effect == "") {
        exec(f"effect clear {targets}")
    } else {
        exec(f"effect clear {targets} {effect}")
    }
}

fn effect_give(targets: string, effect: string, seconds: string = "", amplifier: string = "", hideParticles: string = "") {
    if (seconds == "") {
        exec(f"effect give {targets} {effect}")
    } else if (amplifier == "") {
        exec(f"effect give {targets} {effect} {seconds}")
    } else if (hideParticles == "") {
        exec(f"effect give {targets} {effect} {seconds} {amplifier}")
    } else {
        exec(f"effect give {targets} {effect} {seconds} {amplifier} {hideParticles}")
    }
}

fn effect_give_infinite(targets: string, effect: string, amplifier: string = "", hideParticles: string = "") {
    if (amplifier == "") {
        exec(f"effect give {targets} {effect} infinite")
    } else if (hideParticles == "") {
        exec(f"effect give {targets} {effect} infinite {amplifier}")
    } else {
        exec(f"effect give {targets} {effect} infinite {amplifier} {hideParticles}")
    }
}

