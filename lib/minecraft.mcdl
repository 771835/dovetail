fn data_get_block(targetPos: string, path: string = "", scale: string = "") {
    if (path == "") {
        exec(f"data get block {targetPos}")
    } else if (scale == "") {
        exec(f"data get block {targetPos} {path}")
    } else {
        exec(f"data get block {targetPos} {path} {scale}")
    }
}

fn data_get_entity(target: string, path: string = "", scale: string = "") {
    if (path == "") {
