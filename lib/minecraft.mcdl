// ────────────────────────────────────────────────────────────
// transfer
// ────────────────────────────────────────────────────────────

fn transfer(hostname: string, port: string = "", players: string = "") {
    if (port == "") {
        exec(f"transfer {hostname}")
    } else if (players == "") {
        exec(f"transfer {hostname} {port}")
    } else {
        exec(f"transfer {hostname} {port} {players}")
    }
}

