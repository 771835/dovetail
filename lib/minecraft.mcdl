fn advancement_grant_everything(targets: string) {
    exec(f"advancement grant {targets} everything")
}

fn advancement_grant_from(targets: string, advancement: string) {
    exec(f"advancement grant {targets} from {advancement}")
}

fn advancement_grant_only(targets: string, advancement: string, criterion: string = "") {
    if (criterion == "") {
        exec(f"advancement grant {targets} only {advancement}")
    } else {
        exec(f"advancement grant {targets} only {advancement} {criterion}")
    }
}

