// 程序结构
program: include* (enums|class|struct|function|let|const|typedef)*

include: "include" literal               // 包含库文件，如：include "mathlib.mcdl"

// 注解系统(仅允许使用内置注解及插件注解)
annotation: "@" ID | "@" ID "(" literal ("," literal)* ")"

// 类(多继承)
class: annotation* "class" ID (":" identifier ("," identifier)*)? "{" (class_property | method)* "}"

class_property: "let" ID ":" type

// 结构体
struct: annotation* "struct" ID "{" struct_field* "}"

struct_field: ID ":" type

// 枚举
enums : annotation* "enum" ID "{" (enum_member ("," enum_member)* ","?)? "}"

enum_member : ID "=" literal

// 类型系统
type.2: ID ("<" type ("," type)* ">")? [QUESTION] // 仅对象允许可空(指向null)

function: annotation* ("function"|"fn"|"def") ID params [("->"|":") type] (block|pass_stmt)


method: annotation* "method" ID params [("->"|":") type] (block|pass_stmt)

params : "(" (param ("," param)*)? ")"

// 强制类型标注
param: [MUT] ID ":" type ("=" expr)?
     | [MUT] type ID ("=" expr)?

// 代码块，包含多个语句
?block : "{" statement* "}"

// 流程控制
?statement: function
    | typedef                                 // 类型别名
    | let                                     // 变量声明
    | const                                   // 常量声明
    | for_loop                                // for循环
    | while_loop                              // while循环
    | expr                                    // 表达式
    | if_stmt                                 // 条件语句
    | "free" identifier       -> free         // 手动清理资源(非常危险，极其容易造成空指针等问题)
    | "return" expr?          -> return_stmt  // 返回
    | "break"                 -> break_stmt   // break语句
    | "continue"              -> continue_stmt// continue语句
    | pass_stmt                               // 空语句

typedef: "typedef" type ID

if_stmt : "if" "(" [condition] ")" block ("else" (if_stmt|block))?

pass_stmt: "pass"|";"

for_loop : "for" "(" [let | expr] ";" [condition] ";" [expr] ")" block // 传统for循环
    | "for" "(" type ID ":" expr ")" block       // 增强for循环 (expr需为可迭代class)

while_loop : "while" "(" [condition] ")" block            // while循环

// condition 在语义分析时检查类型
condition: expr

const: "const" ID [":" type] "=" expr  // 常量声明
     | "const" type ID "=" expr

// 变量声明
let: "let" ID "=" expr // 自动推导类型
   | "let" ID ":" type ["=" expr]

// ============ 表达式优先级层次 ============
?expr: or_expr

?or_expr: and_expr
    | or_expr _LOGICAL_OR and_expr -> logical_or

?and_expr: cmp_expr
    | and_expr _LOGICAL_AND cmp_expr -> logical_and

?cmp_expr: add_expr
    | cmp_expr COMPARE_OP add_expr -> compare

?add_expr: mul_expr
    | add_expr ADDSUB mul_expr -> term

?mul_expr: unary_expr
    | mul_expr MULTIPLY unary_expr -> factor

?unary_expr: post_expr
    | ADDSUB unary_expr -> unary_minus
    | _LOGICAL_NOT unary_expr -> logical_not

?post_expr: atom
    | post_expr "." ID arguments -> method_call
    | post_expr "." ID -> member_access
    | post_expr "[" expr "]" -> array_access
    | post_expr arguments -> function_call
    | post_expr "[" expr "]" COMPOUND_ASSIGN expr -> array_assignment
    | post_expr "." ID COMPOUND_ASSIGN expr -> member_assignment
    | identifier COMPOUND_ASSIGN expr -> local_assignment

?atom: primary | FSTRING -> fstring | "null" -> null


// 字面量、标识符（变量、函数、类）、括号
?primary: literal | identifier | paren
?paren: "(" expr ")"


arguments : ("(" (argument ("," argument)*)? ")")

// 当存在mut时代表传入量可变，目前仅对数组有效
argument : [MUT] expr

// 数字、普通字符串、布尔值、空值
literal : INT
    | STRING
    | TRUE
    | FALSE
    | array_literal

// 常量
array_literal: "[" (literal ("," literal)*)? "]"
ARRAY_SIZE: /[1-9][0-9]*/     // 数组大小（正整数）
INT: /-?[0-9]+/               // 整数（可以为负）
// FLOAT: /-?[0-9]+\.[0-9]+/     // 浮点数

// f-string
FSTRING.3: /f"([^"\\]|\\.)*"/

// 运算符
COMPOUND_ASSIGN: "+="|"-="|"*="|"/="|"%="|"="
COMPARE_OP.3: "=="|"!="|"<="|">="|">"|"<"
MULTIPLY: "*"|"/"|"%"
ADDSUB: "-"|"+"
_LOGICAL_AND.2: "and"|"&&"
_LOGICAL_OR.2: "or"|"||"
_LOGICAL_NOT: "not"|"!"
TRUE: "true"
FALSE: "false"

// 标识符(不适用定义)
identifier: ID

// 所有权关键字
MUT.2: "mut"

// 可空关键字
QUESTION: "?"

// 注释
PYTHONIC_COMMENT: /#[^\n]*/
LUA_COMMENT: "[[" /(.|\n)*?/ "]]"

%import common.ESCAPED_STRING -> STRING
%import common.CNAME -> ID
%import common.WS
%import common.CPP_COMMENT
%import common.C_COMMENT
%ignore WS
%ignore CPP_COMMENT
%ignore C_COMMENT
%ignore PYTHONIC_COMMENT
%ignore LUA_COMMENT
